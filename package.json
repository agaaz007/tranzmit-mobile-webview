{
  "name": "tranzmit",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/core",
    "packages/react-native",
    "packages/server"
  ],
  "scripts": {
    "build": "tsc -b --force packages/shared packages/core packages/react-native packages/server",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx packages/server/src/migrations.ts",
    "dev:server": "npm run dev --workspace=packages/server",
    "seed": "node scripts/seed.mjs",
    "smoke:admin": "node scripts/smoke-admin.mjs",
    "test:visual:android": "node scripts/paywall-screenshot-regression.mjs"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "esbuild": "^0.28.0",
    "jsdom": "^24.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
