DATABASE_URL=postgresql://user:password@localhost:5432/tranzmit
ADMIN_SECRET=replace-with-long-random-admin-secret
STATSIG_SERVER_SECRET=secret-xxx
PORT=3000
PUBLIC_API_BASE_URL=https://your-tranzmit-api.up.railway.app

# 60s by default so dashboard edits become visible quickly. SDKs also expose
# refreshConfig() for immediate testing after saving a paywall.
CONFIG_TTL_SECONDS=60

# Default "hosted+inline" keeps old SDKs safe while also exposing CDN-cacheable
# document URLs. Use "hosted" once every mobile app version has the document
# hydration cache.
PAYWALL_DOCUMENT_DELIVERY=hosted+inline
PAYWALL_DOCUMENT_CACHE_TTL_SECONDS=31536000

# Optional seed overrides. Defaults create the Influish demo test client.
SEED_CLIENT_ID=client_influish_demo
SEED_PUBLIC_KEY=pk_test_2a8a5f07d4b9fcf1cc77e024
SEED_SECRET_KEY=sk_test_influish_demo
SEED_CLIENT_NAME=Influish Demo
